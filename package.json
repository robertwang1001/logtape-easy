{
  "name": "logtape-easy",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "description": "A small LogTape helper for apps that provides out-of-the-box logging with a built-in console sink and minimal setup.",
  "author": {
    "name": "robertwang1001",
    "email": "glorywong1001@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/logtape-easy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertwang1001/logtape-easy.git"
  },
  "bugs": {
    "url": "https://github.com/robertwang1001/logtape-easy/issues"
  },
  "keywords": [
    "logger",
    "logging",
    "logtape",
    "console",
    "sink",
    "runtime",
    "browser",
    "server",
    "typescript",
    "javascript",
    "observability",
    "log-level"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepublishOnly": "pnpm test && pnpm build",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "prepare": "pnpm simple-git-hooks",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@logtape/logtape": "2.1.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "lint-staged": "^17.0.5",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit ${1}"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
